+/* chafa-syms-rs parity oracle: dump the fully-initialized builtin symbol
+ * arrays (narrow + wide) to the file named by CHAFA_DUMP_SYMBOLS. This is the
+ * ground truth the Rust port's symbol layer (parsed outlines + ported
+ * braille/sextant/octant generators + tag derivation) is validated against,
+ * neutralizing the GLib-Unicode-version parity risk. No effect unless set. */
+static void
+chafa_syms_rs_dump_symbols (void)
+{
+    const gchar *path = g_getenv ("CHAFA_DUMP_SYMBOLS");
+    FILE *df;
+    gint n, m, i;
+
+    if (!path)
+        return;
+
+    df = fopen (path, "w");
+    if (!df)
+        return;
+
+    for (n = 0; chafa_symbols [n].c; n++)
+        ;
+    for (m = 0; chafa_symbols2 [m].sym [0].c; m++)
+        ;
+
+    fprintf (df, "NARROW %d\n", n);
+    for (i = 0; i < n; i++)
+    {
+        ChafaSymbol *s = &chafa_symbols [i];
+        fprintf (df, "%u %u %d %016" G_GINT64_MODIFIER "x\n",
+                 (unsigned) s->c, (unsigned) s->sc, s->popcount,
+                 (guint64) s->bitmap);
+    }
+
+    fprintf (df, "WIDE %d\n", m);
+    for (i = 0; i < m; i++)
+    {
+        ChafaSymbol2 *s = &chafa_symbols2 [i];
+        fprintf (df, "%u %u %d %d %016" G_GINT64_MODIFIER "x %016" G_GINT64_MODIFIER "x\n",
+                 (unsigned) s->sym [0].c, (unsigned) s->sym [0].sc,
+                 s->sym [0].popcount, s->sym [1].popcount,
+                 (guint64) s->sym [0].bitmap, (guint64) s->sym [1].bitmap);
+    }
+
+    fclose (df);
+}
+
